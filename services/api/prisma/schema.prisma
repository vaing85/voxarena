// VoxArena — PostgreSQL (Supabase). Run: npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supabaseUserId String? @unique @db.Uuid

  email    String? @unique
  name     String?
  deviceId String?

  mmr  Int    @default(1000)
  tier String @default("Bronze") // Bronze | Silver | Gold | Platinum | Diamond | Master

  matchesPlayed Int @default(0)
  matchesWon    Int @default(0)

  performances Performance[]
  matchesAs1   Match[]       @relation("Player1Matches")
  matchesAs2   Match[]       @relation("Player2Matches")
  entitlements Entitlement[]
  cosmetics    CosmeticOwnership[]
}

model Song {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  title       String
  artist      String?
  difficulty  String
  referenceId String?

  /// Reference melody for pitch scoring: array of { start, end, midi } notes
  /// (seconds + MIDI note). Null until authored.
  referenceNotes Json?

  /// When set, the song is locked behind the pack; null = free for everyone.
  packId String?
  pack   SongPack? @relation(fields: [packId], references: [id], onDelete: SetNull)

  performances Performance[]
  matches      Match[]

  @@index([packId])
}

/// A purchasable bundle of songs (monetization: no pay-to-win — content only).
model SongPack {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  slug        String  @unique
  name        String
  description String?

  priceCents Int    @default(0)
  currency   String @default("usd")
  /// Stripe Price id (price_...). Null until a price is wired; pack not purchasable yet.
  stripePriceId String?
  active        Boolean @default(true)

  songs        Song[]
  entitlements Entitlement[]
}

/// Records that a player owns a pack (via purchase or manual grant).
model Entitlement {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  playerId String
  packId   String
  source   String @default("purchase") // purchase | grant

  /// Stripe Checkout Session id — unique so webhook delivery is idempotent.
  stripeSessionId String? @unique

  player Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  pack   SongPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@unique([playerId, packId])
  @@index([playerId])
}

model CosmeticItem {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  slug        String  @unique
  name        String
  description String?
  /// Display category — at most one equipped per category (e.g. frame | title | color).
  category String

  priceCents Int    @default(0)
  currency   String @default("usd")
  /// Stripe Price id; null until wired (item not purchasable yet).
  stripePriceId String?
  active        Boolean @default(true)

  ownerships CosmeticOwnership[]
}

model CosmeticOwnership {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  playerId       String
  cosmeticItemId String
  source         String  @default("purchase") // purchase | grant
  equipped       Boolean @default(false)

  /// Stripe Checkout Session id — unique so webhook delivery is idempotent.
  stripeSessionId String? @unique

  player Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  item   CosmeticItem @relation(fields: [cosmeticItemId], references: [id], onDelete: Cascade)

  @@unique([playerId, cosmeticItemId])
  @@index([playerId])
}

model Performance {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  playerId String
  songId   String
  mode     String // solo_practice | solo_vs_bot | ranked_pvp | tournament

  scorePitch       Float?
  scoreTiming      Float?
  scoreStability   Float?
  scoreDynamics    Float?
  scoreTransitions Float?
  scoreTotal       Float?

  matchId String?
  match   Match?  @relation(fields: [matchId], references: [id], onDelete: SetNull)

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  song   Song   @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId])
  @@index([playerId])
  @@index([matchId])
}

model Match {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  songId     String
  difficulty String

  player1Id String
  player2Id String
  winnerId  String?

  player1Score Float?
  player2Score Float?

  /// pending: waiting for performances — completed: MMR applied
  status String @default("pending")

  /// When the live countdown first triggered (both players present). Lets a
  /// reconnecting client resume an in-progress round instead of restarting it.
  startedAt DateTime?

  player1 Player @relation("Player1Matches", fields: [player1Id], references: [id], onDelete: Cascade)
  player2 Player @relation("Player2Matches", fields: [player2Id], references: [id], onDelete: Cascade)
  song    Song   @relation(fields: [songId], references: [id], onDelete: Cascade)

  performances Performance[]
}
