# VoxArena API — copy to .env and fill in

# --- Database (Supabase Postgres) ---
# Project Settings → Database → Connection string (URI), mode: Transaction / Session
# Local dev: see infra/docker-compose.yml for postgres://postgres:postgres@localhost:5432/voxarena
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/voxarena"

# --- Redis (matchmaking / sessions; optional in Phase 1) ---
REDIS_URL="redis://localhost:6379"

# --- Supabase (Auth + optional Storage / Realtime) ---
# Project Settings → API
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# Server only — never expose to clients or commit
SUPABASE_SERVICE_ROLE_KEY=""
# Optional: anon key for future edge functions / public rules
SUPABASE_ANON_KEY=""

# --- Auth ---
# When Supabase is configured (URL + service role key), write endpoints require
# a Supabase access token: "Authorization: Bearer <token>".
# For local dev WITHOUT Supabase, set AUTH_DEV_BYPASS=true to skip token
# verification and identify the player via an "x-player-id: <uuid>" header.
# Never honored when NODE_ENV=production.
AUTH_DEV_BYPASS="false"

# --- Resend (transactional email) ---
RESEND_API_KEY=""
# Verified sender, e.g. "VoxArena <onboarding@resend.dev>" or your domain after DNS verify
RESEND_FROM=""

# --- Server ---
# Railway sets PORT automatically; local default:
PORT=3000
NODE_ENV=development
