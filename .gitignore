# VoxArena — gitignore

# Env and secrets
.env
.env.local
.env.*.local
*.pem

# Dependencies
node_modules/
.pnp
.pnp.js

# Build
dist/
build/
*.tsbuildinfo

# Prisma — keep migrations/ tracked for Postgres; do not ignore.

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.eggs/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Unity
clients/unity/[Ll]ibrary/
clients/unity/[Tt]emp/
clients/unity/[Oo]bj/
clients/unity/[Bb]uild/
clients/unity/[Bb]uilds/
clients/unity/[Ll]ogs/
clients/unity/[Uu]ser[Ss]ettings/
*.csproj.user

# Godot
clients/godot/.import/
clients/godot/export/
clients/godot/*.translation

# Misc
*.local
.cache/
